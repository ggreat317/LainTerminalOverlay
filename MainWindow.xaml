<Window x:Class="TerminalOverlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:gif="http://wpfanimatedgif.codeplex.com"
        Title="Overlay"
        Width="300"
        Height="300"
        Icon="/assets/lain.ico"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="True"
        ResizeMode="NoResize"
        Loaded="Window_Loaded"
        >

    <Grid Background="Red"
          MouseEnter="MouseEnter"
          PreviewMouseLeftButtonUp="muPrevAdapter"
          PreviewMouseLeftButtonDown="MouseDown"
          LostMouseCapture="muLostAdapter"
          MouseLeave="MouseLeave"
          PreviewMouseMove="MouseMove"
          >
        <Image x:Name="OverlayImage"/>
        
    </Grid>
</Window>